# äGENT çOMBAT backend — Koyeb-ready
#
# Koyeb: create a Docker service from this repo with work directory
# `backend/`, expose port 8000, health check path `/health`.
# WebSockets (combat rooms) work out of the box.

FROM python:3.12-slim AS base

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

# System deps: gcc for any wheels that need building (web3/asyncpg ship
# manylinux wheels, so this stays slim; curl for the container healthcheck)
RUN apt-get update \
 && apt-get install -y --no-install-recommends gcc curl \
 && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install -r requirements.txt

COPY app ./app

# Non-root runtime
RUN useradd -m runner
USER runner

EXPOSE 8000

HEALTHCHECK --interval=30s --timeout=5s --start-period=15s --retries=3 \
  CMD curl -fsS http://localhost:8000/health || exit 1

# Koyeb injects PORT; default to 8000. Single worker on purpose: combat
# rooms and the chain listener hold in-process state — scale vertically,
# or add a shared room store (Redis) before scaling horizontally.
CMD ["sh", "-c", "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"]